const $=s=>document.querySelector(s),gallery=$('#gallery'),filters=$('#filters'),lightbox=$('#lightbox');let photos=[],tag='';
const noDate=value=>!value||value==='0001-01-01',formatDate=value=>noDate(value)?'No date':new Intl.DateTimeFormat(undefined,{year:'numeric',month:'short',day:'numeric'}).format(new Date(`${value}T00:00:00`));
function startCarousel(items){if(!items.length)return;let i=0;const hero=$('#hero'),show=()=>{hero.style.backgroundImage=`linear-gradient(#0009,#0005),url(${items[i].imageUrl})`;i=(i+1)%items.length};show();if(items.length>1)setInterval(show,5000)}
function openPhoto(photo){const image=$('#lightbox-image');image.removeAttribute('src');image.src=photo.imageUrl;if(!lightbox.open)lightbox.showModal()}
function render(){gallery.innerHTML='';photos.filter(p=>!tag||p.tags.includes(tag)).sort((a,b)=>noDate(a.dateTaken)?1:noDate(b.dateTaken)?-1:b.dateTaken.localeCompare(a.dateTaken)).forEach(p=>{const card=document.createElement('article');card.className='photo';card.innerHTML=`<button class="image-button"><img src="${p.thumbnailUrl}" alt="Open photo" loading="lazy"></button><div class="photo-meta"><time>${formatDate(p.dateTaken)}</time><span>${p.tags.map(t=>`<b>${t}</b>`).join('')}</span></div>`;card.querySelector('button').onclick=()=>openPhoto(p);gallery.append(card)})}
filters.onclick=e=>{const b=e.target.closest('button');if(!b)return;tag=b.dataset.tag;filters.querySelectorAll('button').forEach(x=>x.classList.toggle('active',x===b));render()};$('#theme').onclick=()=>{const n=document.documentElement.dataset.theme==='dark'?'light':'dark';document.documentElement.dataset.theme=n;localStorage.theme=n};$('#close-lightbox').onclick=()=>lightbox.close();lightbox.addEventListener('close',()=>$('#lightbox-image').removeAttribute('src'));lightbox.onclick=e=>{if(e.target===lightbox)lightbox.close()};document.documentElement.dataset.theme=localStorage.theme||'dark';
(async()=>{const [siteResponse,photoResponse]=await Promise.all([fetch('/api/site'),fetch('/api/photos')]);const site=await siteResponse.json();photos=await photoResponse.json();$('#site-title').textContent=site.site_title||"Ben's Lens";$('#camera').textContent=site.camera||'';const carousel=photos.filter(p=>p.featured);if(carousel.length)startCarousel(carousel);else if(site.banner_key)$('#hero').style.backgroundImage=`linear-gradient(#0008,#0008),url(/site-media/banner)`;if(site.profile_key){$('#profile').src='/site-media/profile';$('#profile').hidden=false}const links=[];if(site.email)links.push(`<a href="mailto:${site.email}">${site.email}</a>`);if(site.phone)links.push(`<a href="tel:${site.phone}">${site.phone}</a>`);if(site.instagram_url)links.push(`<a href="${site.instagram_url}" target="_blank" rel="noreferrer">Instagram</a>`);$('#contact').innerHTML=links.join('');render()})().catch(()=>gallery.textContent='Gallery unavailable.');
